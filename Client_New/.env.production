# Build-time API URL. Railway injects VITE_API_URL as an environment variable
# during the build step, which takes precedence over this file. If it is not
# injected, the value below is compiled into the bundle. The fallback in
# api.js will use the private internal DNS when this variable is absent.
VITE_API_URL=https://tiara-management-app-production.up.railway.app/api
