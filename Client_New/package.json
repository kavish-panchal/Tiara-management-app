{
  "name": "inventory-management-app",
  "version": "1.0.0",
  "main": "electron.js",
  "homepage": "./",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "node_modules/.bin/electron.cmd .",
    "electron-dev": "concurrently \"cross-env BROWSER=none npm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development node_modules/.bin/electron.cmd .\"",
    "electron-start": "cross-env NODE_ENV=development node_modules/.bin/electron.cmd .",
    "electron-build": "npm run build && node_modules/.bin/electron-builder.cmd",
    "dist": "npm run build && npx electron-builder --win --publish never"
  },
  "dependencies": {
    "axios": "^1.x.x",
    "express": "^4.18.2",
    "lucide-react": "^0.x.x",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.x.x",
    "zustand": "^4.x.x",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@vitejs/plugin-react": "^4.x.x",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-updater": "^6.8.3",
    "tailwindcss": "^4.2.4",
    "vite": "^5.x.x",
    "wait-on": "^9.0.5"
  },
  "build": {
    "appId": "com.Tiara.inventory-management",
    "productName": "Inventory Management",
    "files": [
      "dist/**/*",
      "electron.js",
      "public/**/*",
      "node_modules/electron-updater/**/*"
    ],
    "directories": {
      "buildResources": "public",
      "output": "build-output"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "kavish-panchal",
      "repo": "Tiara-management-app"
    }
  }
}
